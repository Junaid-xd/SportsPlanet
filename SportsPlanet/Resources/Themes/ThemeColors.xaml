<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <!-- Backgrounds -->
    <Color x:Key="PrimaryBgColor">#0F172A</Color>
    <Color x:Key="CardBgColor">#1E293B</Color>
    <Color x:Key="HoverBgColor">#273449</Color>

    <!-- Brushes (IMPORTANT) -->
    <SolidColorBrush x:Key="PrimaryBg" Color="{StaticResource PrimaryBgColor}" />
    <SolidColorBrush x:Key="CardBg" Color="{StaticResource CardBgColor}" />
    <SolidColorBrush x:Key="HoverBg" Color="{StaticResource HoverBgColor}" />

    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryText" Color="White"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#94A3B8"/>
    <SolidColorBrush x:Key="MutedText" Color="#CBD5E1"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="PrimaryBlue" Color="#2563EB"/>

    <!-- Status -->
    <SolidColorBrush x:Key="Success" Color="#22C55E"/>
    <SolidColorBrush x:Key="Danger" Color="#EF4444"/>
    <SolidColorBrush x:Key="Warning" Color="#FACC15"/>

    <!-- ================= MENU BUTTON STYLE ================= -->
    <Style x:Key="MenuButtonStyle" TargetType="Button">

        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryText}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Margin" Value="5,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="13"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">

                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource HoverBg}"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
                        </Trigger>

                        <!-- Click -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.8"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>

</ResourceDictionary>