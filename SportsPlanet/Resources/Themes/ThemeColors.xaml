
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ================= BASE COLORS ================= -->

    <Color x:Key="PrimaryBgColor">#0F172A</Color>
    <Color x:Key="SurfaceColor">#1E293B</Color>
    <Color x:Key="SurfaceAltColor">#111827</Color>
    <Color x:Key="HoverColor">#273449</Color>

    <!-- ================= BRUSHES ================= -->

    <SolidColorBrush x:Key="PrimaryBg" Color="{StaticResource PrimaryBgColor}"/>
    <SolidColorBrush x:Key="CardBg" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CartPanelBg" Color="{StaticResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="CartItemBg" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CartSummaryBg" Color="{StaticResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="HoverBg" Color="{StaticResource HoverColor}"/>

    <!-- ================= TEXT ================= -->

    <SolidColorBrush x:Key="PrimaryText" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#94A3B8"/>
    <SolidColorBrush x:Key="MutedText" Color="#CBD5E1"/>
    <!-- ✅ FIXED -->
    <SolidColorBrush x:Key="OnPrimaryText" Color="White"/>

    <!-- ================= INPUT ================= -->

    <SolidColorBrush x:Key="InputBg" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="InputText" Color="#E5E7EB"/>

    <!-- ================= ACCENT ================= -->

    <SolidColorBrush x:Key="PrimaryBlue" Color="#2563EB"/>

    <!-- ================= STATUS ================= -->

    <SolidColorBrush x:Key="Success" Color="#22C55E"/>
    <SolidColorBrush x:Key="Danger" Color="#EF4444"/>
    <SolidColorBrush x:Key="Warning" Color="#FACC15"/>

    <!-- ================= OVERLAY ================= -->

    <SolidColorBrush x:Key="OverlayBg" Color="#80000000"/>

    <!-- ================= MENU BUTTON ================= -->

    <Style x:Key="MenuButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryText}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Margin" Value="5,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="13"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource HoverBg}"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.8"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>