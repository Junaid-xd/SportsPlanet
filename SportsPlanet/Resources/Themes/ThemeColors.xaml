
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ================= BASE COLORS ================= -->

    <Color x:Key="PrimaryBgColor">#0F172A</Color>
    <Color x:Key="SurfaceColor">#1E293B</Color>
    <Color x:Key="SurfaceAltColor">#111827</Color>
    <Color x:Key="HoverColor">#273449</Color>

    <!-- ================= HEADER ACTIVE STATE ================= -->

    <Color x:Key="ActiveButtonBgColor">#1D4ED8</Color>
    <Color x:Key="ActiveButtonTextColor">#FFFFFF</Color>

    <!-- ================= BRUSHES ================= -->

    <SolidColorBrush x:Key="PrimaryBg" Color="{StaticResource PrimaryBgColor}"/>
    <SolidColorBrush x:Key="CardBg" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CartPanelBg" Color="{StaticResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="CartItemBg" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CartSummaryBg" Color="{StaticResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="HoverBg" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="ActiveButtonBg" Color="{StaticResource ActiveButtonBgColor}"/>
    <SolidColorBrush x:Key="ActiveButtonText" Color="{StaticResource ActiveButtonTextColor}"/>
    
    
    <!-- ================= HOVER FOR HEADER BUTTONS ================= -->
    <Color x:Key="ActiveButtonHoverColor">#2563EB</Color>


    <!-- ================= ORDER STATUS COLORS ================= -->

    <SolidColorBrush x:Key="StatusPending" Color="#F59E0B"/>
    <SolidColorBrush x:Key="StatusProcessing" Color="#3B82F6"/>
    <SolidColorBrush x:Key="StatusCompleted" Color="#22C55E"/>
    <SolidColorBrush x:Key="StatusCancelled" Color="#EF4444"/>

    <!-- ================= ORDER UI ================= -->

    <SolidColorBrush x:Key="OrderCardBorder" Color="#334155"/>
    <SolidColorBrush x:Key="OrderHeaderBg" Color="#111C2E"/>
    <SolidColorBrush x:Key="OrderItemBgAlt" Color="#0B1220"/>

    <!-- ================= TEXT ================= -->

    <SolidColorBrush x:Key="PrimaryText" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#94A3B8"/>
    <SolidColorBrush x:Key="MutedText" Color="#CBD5E1"/>
    <SolidColorBrush x:Key="OnPrimaryText" Color="White"/>

    <!-- ================= INPUT ================= -->

    <SolidColorBrush x:Key="InputBg" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="InputText" Color="#E5E7EB"/>

    <!-- ================= ACCENT ================= -->

    <SolidColorBrush x:Key="PrimaryBlue" Color="#2563EB"/>

    <!-- ================= STATUS ================= -->

    <SolidColorBrush x:Key="Success" Color="#22C55E"/>
    <SolidColorBrush x:Key="Danger" Color="#EF4444"/>
    <SolidColorBrush x:Key="Warning" Color="#FACC15"/>

    <!-- ================= OVERLAY ================= -->

    <SolidColorBrush x:Key="OverlayBg" Color="#80000000"/>

    <!-- ================= MENU BUTTON ================= -->
    

    <Style x:Key="MenuButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryText}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Margin" Value="5,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="13"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource HoverBg}"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.8"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ================= PRIMARY BUTTON ================= -->

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">

        <!-- Default -->
        <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
        <Setter Property="Foreground" Value="{StaticResource OnPrimaryText}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>

        <!-- Template -->
        <Setter Property="Template">
            <Setter.Value>

                <ControlTemplate TargetType="Button">

                    <Border x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}">

                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder"
                                Property="Background"
                                Value="#1D4ED8"/>
                        </Trigger>

                        <!-- Pressed -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder"
                                Property="Opacity"
                                Value="0.85"/>
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder"
                                Property="Opacity"
                                Value="0.5"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>
        </Setter>

    </Style>

    <!-- ================= DANGER BUTTON ================= -->

    <Style x:Key="DangerButtonStyle" TargetType="Button">

        <Setter Property="Background" Value="{StaticResource Danger}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>

        <Setter Property="Template">
            <Setter.Value>

                <ControlTemplate TargetType="Button">

                    <Border x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}">

                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder"
                                Property="Background"
                                Value="#DC2626"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder"
                                Property="Opacity"
                                Value="0.85"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>
        </Setter>

    </Style>

    <!-- ================= SECONDARY BUTTON ================= -->

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">

        <Setter Property="Background" Value="{StaticResource HoverBg}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>

        <Setter Property="Template">
            <Setter.Value>

                <ControlTemplate TargetType="Button">

                    <Border x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}">

                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder"
                                Property="Background"
                                Value="#334155"/>
                            <Setter Property="Foreground"
                                Value="{StaticResource PrimaryText}"/>
                        </Trigger>

                        <!-- Pressed -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder"
                                Property="Opacity"
                                Value="0.85"/>
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder"
                                Property="Opacity"
                                Value="0.5"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>
        </Setter>

    </Style>

    <!-- ================= SUPER ADMIN REPORTS ================= -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBg}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="15"/>
        <Setter Property="Margin" Value="10"/>
        <Setter Property="BorderBrush" Value="{StaticResource OrderCardBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="KpiTextTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SecondaryText}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style x:Key="KpiTextValue" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    
    
   

</ResourceDictionary>