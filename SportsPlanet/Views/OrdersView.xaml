<Page x:Class="SportsPlanet.Views.OrdersView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:components="clr-namespace:SportsPlanet.Components"
      xmlns:conv="clr-namespace:SportsPlanet.Converters"
      Title="OrdersView">

    <!-- RESOURCES -->
    <Page.Resources>
        <conv:UnixToDateConverter x:Key="UnixToDateConverter"/>
    </Page.Resources>

    <Grid Background="{StaticResource PrimaryBg}">

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <components:Header x:Name="HeaderControl" Grid.Row="0"/>

        <!-- CONTENT -->
        <ScrollViewer Margin="0,15,0,0" Grid.Row="1">

            <StackPanel>

                <!-- PAGE TITLE -->
                <TextBlock Text="Your Orders"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryText}"
                           Margin="20,0,20,20"/>



                <ItemsControl Name="OrdersItemsControl">

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <!-- ORDER CARD -->
                            <Border Background="{StaticResource CardBg}"
                                    BorderBrush="{StaticResource OrderCardBorder}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Margin="20,0,20,18"
                                    Padding="18">

                                <StackPanel>

                                    <!-- HEADER -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- LEFT: ORDER META -->
                                        <StackPanel>

                                            <TextBlock Text="Order ID"
                                       Foreground="{StaticResource SecondaryText}"
                                       FontSize="11"/>

                                            <TextBlock Text="{Binding Id, StringFormat=# {0}}"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0,0,0,6"/>

                                            <TextBlock Text="Placed On"
                                       Foreground="{StaticResource SecondaryText}"
                                       FontSize="11"/>

                                            <TextBlock Foreground="{StaticResource PrimaryText}"
                                       FontSize="13">
                                                <TextBlock.Text>
                                                    <Binding Path="CreatedAt"
                                             Converter="{StaticResource UnixToDateConverter}"/>
                                                </TextBlock.Text>
                                            </TextBlock>

                                        </StackPanel>

                                        <!-- STATUS -->
                                        <Border Grid.Column="1"
                                Padding="10,5"
                                CornerRadius="20"
                                Background="{StaticResource StatusProcessing}"
                                VerticalAlignment="Top">

                                            <TextBlock Text="{Binding Status}"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontSize="12"/>
                                        </Border>
                                    </Grid>

                                    <!-- DIVIDER -->
                                    <Border Height="1"
                                            Background="{StaticResource HoverBg}"
                                            Margin="0,8,0,12"/>

                                    <!-- DELIVERY INFO -->
                                    <StackPanel Margin="0,0,0,12">

                                        <TextBlock Text="Delivery Address"
                                                   Foreground="{StaticResource SecondaryText}"
                                                   FontSize="12"/>

                                        <TextBlock Text="{Binding Address}"
                                                   Foreground="{StaticResource PrimaryText}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- ITEMS HEADER -->
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Item"
                                                   Foreground="{StaticResource SecondaryText}"
                                                   FontSize="12"/>

                                        <TextBlock Text="Qty"
                                                   Grid.Column="1"
                                                   Margin="20,0"
                                                   Foreground="{StaticResource SecondaryText}"
                                                   FontSize="12"/>

                                        <TextBlock Text="Price"
                                                   Grid.Column="2"
                                                   Foreground="{StaticResource SecondaryText}"
                                                   FontSize="12"/>
                                    </Grid>

                                    <!-- ORDER ITEMS -->
                                    <ItemsControl ItemsSource="{Binding OrderItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>

                                                <Grid Margin="0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- PRODUCT -->
                                                    <TextBlock Text="{Binding Product.ProductName}"
                                                               Foreground="{StaticResource PrimaryText}"
                                                               FontWeight="SemiBold"/>

                                                    <!-- QTY -->
                                                    <TextBlock Grid.Column="1"
                                                               Margin="20,0"
                                                               Text="{Binding Quantity}"
                                                               Foreground="{StaticResource PrimaryText}"/>

                                                    <!-- PRICE -->
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Price, StringFormat=Rs. {0}}"
                                                               Foreground="{StaticResource PrimaryText}"/>

                                                </Grid>

                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- DIVIDER -->
                                    <Border Height="1"
                                            Background="{StaticResource HoverBg}"
                                            Margin="0,12,0,10"/>

                                    <!-- TOTAL -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Total Amount"
                                                   Foreground="{StaticResource SecondaryText}"
                                                   FontSize="13"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TotalAmount, StringFormat=Rs. {0}}"
                                                   Foreground="{StaticResource PrimaryText}"
                                                   FontWeight="Bold"
                                                   FontSize="15"/>
                                    </Grid>

                                    <Button Content="Print Receipt"
                                            Margin="0,12,0,0"
                                            Padding="10,6"
                                            HorizontalAlignment="Right"
                                            Background="Green"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Tag="{Binding Id}"
                                            Click="PrintReceiptClick"/>

                                </StackPanel>

                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </StackPanel>

        </ScrollViewer>

    </Grid>
</Page>

