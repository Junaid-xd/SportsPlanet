<Page x:Class="SportsPlanet.Views.OrdersView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:components="clr-namespace:SportsPlanet.Components"
      Title="OrdersView">

    <Grid Background="{StaticResource PrimaryBg}">

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <components:Header x:Name="HeaderControl" Grid.Row="0"/>

        <!-- CONTENT -->
        <ScrollViewer Margin="0,70,0,0" Grid.Row="1">

            <StackPanel>

                <!-- PAGE TITLE -->
                <TextBlock Text="Your Orders"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryText}"
                           Margin="20,10,20,20"/>

                <ItemsControl Name="OrdersItemsControl">

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <!-- ORDER CARD -->
                            <Border Background="{StaticResource CardBg}"
                                    BorderBrush="{StaticResource OrderCardBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Margin="20,0,20,15"
                                    Padding="15">

                                <StackPanel>

                                    <!-- HEADER -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>

                                            <TextBlock Text="{Binding Id, StringFormat=Order #{0}}"
                                                       Foreground="{StaticResource PrimaryText}"
                                                       FontSize="16"
                                                       FontWeight="Bold"/>

                                            <TextBlock Text="{Binding CreatedAt}"
                                                       Foreground="{StaticResource SecondaryText}"
                                                       FontSize="12"
                                                       Margin="0,3,0,0"/>

                                        </StackPanel>

                                        <!-- STATUS BADGE -->
                                        <Border Grid.Column="1"
                                                Padding="8,4"
                                                CornerRadius="20"
                                                Background="{StaticResource StatusProcessing}">

                                            <TextBlock Text="{Binding Status}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"/>
                                        </Border>

                                    </Grid>

                                    <!-- DIVIDER -->
                                    <Border Height="1"
                                            Background="{StaticResource HoverBg}"
                                            Margin="0,5,0,10"/>

                                    <!-- ADDRESS -->
                                    <TextBlock Text="{Binding Address}"
                                               Foreground="{StaticResource SecondaryText}"
                                               FontSize="13"
                                               Margin="0,0,0,10"/>

                                    <!-- ORDER ITEMS -->
                                    <ItemsControl ItemsSource="{Binding OrderItems}">

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>

                                                <Border Background="{StaticResource CartItemBg}"
                                                        CornerRadius="8"
                                                        Padding="10"
                                                        Margin="0,0,0,8">

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- PRODUCT INFO -->
                                                        <StackPanel>

                                                            <TextBlock Text="{Binding Product.ProductName}"
                                                                       Foreground="{StaticResource PrimaryText}"
                                                                       FontWeight="SemiBold"/>

                                                            <TextBlock Text="{Binding Price, StringFormat=Rs. {0}}"
                                                                       Foreground="{StaticResource SecondaryText}"
                                                                       FontSize="12"/>

                                                        </StackPanel>

                                                        <!-- QTY -->
                                                        <Border Grid.Column="1"
                                                                Background="{StaticResource HoverBg}"
                                                                Padding="8,3"
                                                                CornerRadius="6">

                                                            <TextBlock Text="{Binding Quantity, StringFormat=Qty: {0}}"
                                                                       Foreground="{StaticResource PrimaryText}"
                                                                       FontSize="12"/>
                                                        </Border>

                                                    </Grid>

                                                </Border>

                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>

                                    </ItemsControl>

                                    <!-- TOTAL -->
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Total"
                                                   Foreground="{StaticResource SecondaryText}"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TotalAmount, StringFormat=Rs. {0}}"
                                                   Foreground="{StaticResource PrimaryText}"
                                                   FontWeight="Bold"/>
                                    </Grid>

                                </StackPanel>

                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </StackPanel>

        </ScrollViewer>

    </Grid>
</Page>

