    
<Page x:Class="SportsPlanet.Views.AdminManageProducts"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:components="clr-namespace:SportsPlanet.Components"
      Title="AdminManageProducts">

    <Grid Background="{StaticResource PrimaryBg}">

        <!-- ================= MAIN ================= -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <components:Header x:Name="HeaderControl"/>

            <StackPanel Grid.Row="1" Margin="10">

                
                    <Button Grid.Column="5"
                            Content="+ Add Product"
                            Width="150"
                            Height="35"
                            Background="{StaticResource PrimaryBlue}"
                            Foreground="{StaticResource OnPrimaryText}"
                            BorderThickness="0"
                            HorizontalAlignment="Right"
                            Margin="0 0 10 10"
                            Click="OpenAddProductPopup"/>

                <!-- PRODUCTS LIST -->
                <ScrollViewer Grid.Row="1">
                    <ItemsControl Name="ProductsItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="200"
                          Margin="10"
                          Padding="10"
                          Background="{StaticResource CardBg}"
                          BorderBrush="#99FFFFFF"
                          BorderThickness="1"
                          CornerRadius="5">

                                    <StackPanel>

                                        <Image Height="120"
                                 Stretch="UniformToFill"
                                 Source="{Binding ImgPath, IsAsync=True}"/>

                                        <TextBlock Text="{Binding ProductName}"
                                     Foreground="{StaticResource PrimaryText}"
                                     FontWeight="Bold"
                                     Margin="0,10,0,0"/>

                                        <TextBlock Text="{Binding Price, StringFormat=Rs. {0}}"
                                     Foreground="{StaticResource SecondaryText}"/>

                                        <TextBlock Text="{Binding Quantity}"
                                     Foreground="LightGreen"/>

                                        <!-- EDIT BUTTON -->
                                        <Button Content="Edit"
                                  Margin="0,10,0,0"
                                  Background="{StaticResource PrimaryBlue}"
                                  Foreground="{StaticResource OnPrimaryText}"
                                  BorderThickness="0"
                                  Tag="{Binding}"
                                  Click="EditProductClick"/>
                                    </StackPanel>

                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </StackPanel>

          
        </Grid>

        <!-- ================= EDIT POPUP ================= -->
        <Grid x:Name="EditOverlay"
              Background="{StaticResource OverlayBg}"
              Visibility="Collapsed"
              Panel.ZIndex="999">

            <Border Width="500"
                    Padding="20"
                    Background="{StaticResource CardBg}"
                    CornerRadius="8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel>

                    <TextBlock Text="Edit Product"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryText}"
                               HorizontalAlignment="Center"/>

                    <!-- NAME -->
                    <TextBlock Text="Name" Margin="0,15,0,5"
                               Foreground="{StaticResource SecondaryText}"/>
                    <TextBox x:Name="NameBox"/>

                    <!-- PRICE -->
                    <TextBlock Text="Price" Margin="0,10,0,5"
                               Foreground="{StaticResource SecondaryText}"/>
                    <TextBox x:Name="PriceBox"/>

                    <!-- QUANTITY -->
                    <TextBlock Text="Quantity" Margin="0,10,0,5"
                               Foreground="{StaticResource SecondaryText}"/>
                    <TextBox x:Name="QuantityBox"/>

                    <!-- IMAGE -->
                    <StackPanel>
                        <TextBlock Text="Image"
                                   Margin="0,10,0,5"
                                   Foreground="{StaticResource SecondaryText}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="ImageBox"
                                     Grid.Column="0"
                                     Margin="0,0,10,0"/>

                            <Button Content="Browse"
                                    Grid.Column="1"
                                    Background="{StaticResource PrimaryBlue}"
                                    Foreground="White"
                                    Padding="8,4"
                                    Click="BrowseImageClick"/>
                        </Grid>
                    </StackPanel>

                    <!-- TAGS -->
                    <TextBlock Text="Tags" Margin="0,10,0,5"
                               Foreground="{StaticResource SecondaryText}"/>
                    <TextBox x:Name="TagsBox"/>

                    <!-- BUTTONS -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,20,0,0">

                        <Button Content="Delete"
                                Background="{StaticResource Danger}"
                                Foreground="White"
                                Margin="0,0,10,0"
                                Click="DeleteProductClick"/>

                        <Button Content="Update"
                                Background="{StaticResource PrimaryBlue}"
                                Foreground="White"
                                Margin="0,0,10,0"
                                Click="UpdateProductClick"/>

                        <Button Content="Close"
                                Background="Transparent"
                                Foreground="{StaticResource SecondaryText}"
                                Click="CloseOverlay"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>


        <!-- ================= ADD POPUP ================= -->
        <Grid x:Name="AddOverlay"
              Background="{StaticResource OverlayBg}"
              Visibility="Collapsed"
              Panel.ZIndex="999">

            <Border Width="500"
                    Padding="20"
                    Background="{StaticResource CardBg}"
                    CornerRadius="5"
                    HorizontalAlignment="Center"
                    BorderBrush="#FFFFFF"
                    BorderThickness="2"
                    VerticalAlignment="Center">

                <StackPanel>

                    <!-- TITLE -->
                    <TextBlock Text="Add Product"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryText}"
                               HorizontalAlignment="Center"/>

                    <!-- NAME -->
                    <TextBlock Text="Product Name"
                               Margin="0,15,0,5"
                               Foreground="{StaticResource SecondaryText}"/>
                    <TextBox x:Name="AddNameBox"
                             Height="35"
                             Padding="8"
                             Background="{StaticResource PrimaryBg}"
                             Foreground="{StaticResource PrimaryText}"
                             BorderBrush="#334155"/>

                    <!-- PRICE -->
                    <TextBlock Text="Price (Rs.)"
                               Margin="0,10,0,5"
                               Foreground="{StaticResource SecondaryText}"/>
                    <TextBox x:Name="AddPriceBox"
                            Height="35"
                            Padding="8"
                            Background="{StaticResource PrimaryBg}"
                            Foreground="{StaticResource PrimaryText}"/>

                    <!-- QUANTITY -->
                    <TextBlock Text="Quantity"
                               Margin="0,10,0,5"
                               Foreground="{StaticResource SecondaryText}"/>
                    
                    <TextBox x:Name="AddQuantityBox"
                             Height="35"
                             Padding="8"
                             Background="{StaticResource PrimaryBg}"
                             Foreground="{StaticResource PrimaryText}"/>

                    <!-- IMAGE -->
                    <TextBlock Text="Product Image"
                               Margin="0,10,0,5"
                               Foreground="{StaticResource SecondaryText}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="AddImageBox"
                                 Height="35"
                                 Padding="8"
                                 Background="{StaticResource PrimaryBg}"
                                 Foreground="{StaticResource PrimaryText}"
                                 Margin="0,0,10,0"/>

                        <Button Content="Browse"
                                Grid.Column="1"
                                Background="{StaticResource PrimaryBlue}"
                                Foreground="White"
                                Padding="10,5"
                                Click="BrowseAddImageClick"/>
                    </Grid>

                    <!-- TAGS -->
                    <TextBlock Text="Tags (comma separated)"
                               Margin="0,10,0,5"
                               Foreground="{StaticResource SecondaryText}"/>
                    <TextBox x:Name="AddTagsBox"
                             Height="35"
                             Padding="8"
                             Background="{StaticResource PrimaryBg}"
                             Foreground="{StaticResource PrimaryText}"/>

                    <!-- BUTTONS -->
                    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,20,0,0">

                        <Button Content="Cancel"
                Width="90"
                Height="35"
                Margin="0,0,10,0"
                Background="Transparent"
                Foreground="{StaticResource SecondaryText}"
                BorderBrush="#334155"
                Click="CloseAddPopup"/>

                        <Button Content="Add Product"
                                        Width="120"
                                        Height="35"
                                        Background="{StaticResource PrimaryBlue}"
                                        Foreground="{StaticResource OnPrimaryText}"
                                        BorderThickness="0"
                                        Click="AddProductClick"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
