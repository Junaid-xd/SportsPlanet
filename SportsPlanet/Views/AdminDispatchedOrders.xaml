<Page x:Class="SportsPlanet.Views.AdminDispatchedOrders"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:components="clr-namespace:SportsPlanet.Components"
      xmlns:conv="clr-namespace:SportsPlanet.Converters"
      Title="AdminDispatchedOrders">

    <Page.Resources>
        <conv:UnixToDateConverter x:Key="UnixToDateConverter"/>
    </Page.Resources>

    <Grid>

        <!-- MAIN -->
        <Grid Background="{StaticResource PrimaryBg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <components:Header x:Name="HeaderControl"/>

            <!-- DATE FILTER -->
            <StackPanel Grid.Row="1"
            Orientation="Vertical"
            HorizontalAlignment="Center"
            Margin="0,10">

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <!-- FROM -->
                    <StackPanel Margin="5">
                        <TextBlock Text="From"
                       Foreground="{StaticResource SecondaryText}"
                       HorizontalAlignment="Center"/>
                        <DatePicker x:Name="FromDatePicker" Width="140"/>
                    </StackPanel>

                    <!-- TO -->
                    <StackPanel Margin="5">
                        <TextBlock Text="To"
                                   Foreground="{StaticResource SecondaryText}"
                                   HorizontalAlignment="Center"/>
                        <DatePicker x:Name="ToDatePicker" Width="140"/>
                    </StackPanel>

                    <!-- BUTTONS -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="10,0">
                        <Button Content="Filter"
                                Margin="5"
                                Padding="10,5"
                                Background="{StaticResource PrimaryBlue}"
                                Foreground="White"
                                Click="FilterClick"/>

                        <Button Content="Reset"
                                Margin="5"
                                Padding="10,5"
                                Background="#444"
                                Foreground="White"
                                Click="ResetFilterClick"/>
                    </StackPanel>

                </StackPanel>

                <!-- FILTER STATUS -->
                <TextBlock x:Name="FilterStatusText"
                           Text="Showing all orders"
                           Margin="0,5,0,0"
                           Foreground="{StaticResource SecondaryText}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- ORDERS -->
            <ScrollViewer Grid.Row="2"
                          HorizontalScrollBarVisibility="Disabled">

                <Grid HorizontalAlignment="Center">
                    <ItemsControl x:Name="OrdersItemsControl">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <Border Width="360"
                                        Margin="12"
                                        Padding="16"
                                        CornerRadius="10"
                                        Background="{StaticResource CardBg}"
                                        BorderBrush="#2D3748"
                                        BorderThickness="1">

                                    <StackPanel>

                                        <!-- CUSTOMER -->
                                        <TextBlock Text="{Binding User.Email}"
                                                   Foreground="{StaticResource PrimaryText}"/>

                                        <!-- DATE -->
                                        <TextBlock Margin="0,5,0,0"
                                                   Foreground="{StaticResource PrimaryText}">
                                            <TextBlock.Text>
                                                <Binding Path="CreatedAt"
                                                         Converter="{StaticResource UnixToDateConverter}"/>
                                            </TextBlock.Text>
                                        </TextBlock>

                                        <!-- ADDRESS -->
                                        <TextBlock Text="{Binding Address}"
                                                   Margin="0,5"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource SecondaryText}"/>

                                        <!-- TOTAL -->
                                        <TextBlock Text="{Binding TotalAmount, StringFormat=Rs. {0}}"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryText}"/>

                                        <!-- STATUS (GREEN) -->
                                        <TextBlock Text="{Binding Status}"
                                                   Foreground="LightGreen"
                                                   FontWeight="Bold"
                                                   Margin="0,5"/>

                                        <!-- ACTION -->
                                        <Button Content="View"
                                                HorizontalAlignment="Right"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Tag="{Binding}"
                                                Click="ViewDetailsClick"/>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                </Grid>

            </ScrollViewer>

        </Grid>

        <!-- DETAILS POPUP  -->
        <Grid x:Name="DetailsOverlay"
              Background="{StaticResource OverlayBg}"
              Visibility="Collapsed"
              Panel.ZIndex="999">

            <Border Width="600"
                    Padding="20"
                    Background="{StaticResource CardBg}"
                    CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel>

                    <TextBlock Text="Order Details"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource PrimaryText}"/>

                   


                    <Border Background="{StaticResource HoverBg}"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,10,0,10">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Customer -->
                            <TextBlock Text="Customer:"
                                        Foreground="{StaticResource SecondaryText}"
                                        FontWeight="SemiBold"/>
                            <TextBlock x:Name="CustomerText"
                                       Grid.Column="1"
                                       Foreground="{StaticResource PrimaryText}"/>

                            <!-- Address -->
                            <TextBlock Text="Address:"
                                       Grid.Row="1"
                                       Foreground="{StaticResource SecondaryText}"
                                       FontWeight="SemiBold"
                                       Margin="0,6,0,0"/>
                            <TextBlock x:Name="AddressText"
                                       Grid.Row="1"
                                       Grid.Column="1"
                                       Foreground="{StaticResource PrimaryText}"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap"/>

                            <!-- Delivery -->
                            <TextBlock Text="Delivery:"
                                       Grid.Row="2"
                                       Foreground="{StaticResource SecondaryText}"
                                       FontWeight="SemiBold"
                                       Margin="0,6,0,0"/>
                            <TextBlock x:Name="DeliveryText"
                                       Grid.Row="2"
                                       Grid.Column="1"
                                       Foreground="{StaticResource PrimaryText}"
                                       Margin="0,6,0,0"/>

                            <!-- Total -->
                            <TextBlock Text="Total:"
                                       Grid.Row="3"
                                       Foreground="{StaticResource SecondaryText}"
                                       FontWeight="SemiBold"
                                       Margin="0,6,0,0"/>
                            <TextBlock x:Name="TotalText"
                                       Grid.Row="3"
                                       Grid.Column="1"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontWeight="Bold"
                                       Margin="0,6,0,0"/>
                        </Grid>

                    </Border>


                    <Border Background="{StaticResource CardBg}"
                            CornerRadius="8"
                            Padding="8">

                        <ScrollViewer MaxHeight="200"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">

                            <ItemsControl x:Name="DetailsItemsControl">

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <Border Background="{StaticResource HoverBg}"
                            CornerRadius="6"
                            Padding="8"
                            Margin="0,4">

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="90"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- PRODUCT NAME -->
                                                <TextBlock Text="{Binding Product.ProductName}"
                                       Foreground="{StaticResource PrimaryText}"
                                       VerticalAlignment="Center"
                                       FontSize="13"/>

                                                <!-- QUANTITY -->
                                                <Border Grid.Column="1"
                                    Background="{StaticResource InputBg}"
                                    CornerRadius="5"
                                    Padding="4"
                                    HorizontalAlignment="Center">

                                                    <TextBlock Text="{Binding Quantity}"
                                           Foreground="{StaticResource PrimaryText}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                                </Border>

                                                <!-- PRICE -->
                                                <TextBlock Grid.Column="2"
                                       Text="{Binding Price, StringFormat=Rs. {0}}"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>

                                            </Grid>

                                        </Border>

                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>

                            </ItemsControl>

                        </ScrollViewer>

                    </Border>

                    <Button Content="Close"
                           Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Right"
                            Click="CloseDetails"/>

                </StackPanel>

            </Border>
        </Grid>

    </Grid>
</Page>
