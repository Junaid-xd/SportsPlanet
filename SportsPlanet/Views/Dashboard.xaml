<Page x:Class="SportsPlanet.Views.Dashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SportsPlanet.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Dashboard"
      Loaded="PageLoaded">

    <Grid Background="{StaticResource PrimaryBg}">

        <!-- ================= HEADER ================= -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource CardBg}" Padding="15">
            <DockPanel>

                <!-- BRAND -->
                <TextBlock Text="Sports Planet"
                           Foreground="{StaticResource PrimaryText}"
                           FontSize="20"
                           FontWeight="Bold"
                           DockPanel.Dock="Left"/>

                <!-- MENU -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Content="New Arrivals" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Bats" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Balls" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Badminton" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Kits" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Orders" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Cart" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Login" Click="LoginClick" Name="loginBtn"/>
                    <Button Content="Signup" Click="SignupClick" Name="signupBtn"/>
                    <Button Content="Logout" Click="LogoutClick" Name="logoutBtn"/>

                    <!-- ADMIN -->
                    <Button Content="Stats"
                            Style="{StaticResource MenuButtonStyle}"
                            Visibility="Collapsed"
                            x:Name="StatsBtn"/>

                    <Button Content="Manage Products"
                            Style="{StaticResource MenuButtonStyle}"
                            Visibility="Collapsed"
                            x:Name="ManageProductsBtn"/>

                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ================= CONTENT ================= -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0*" x:Name="CartColumn"/>
            </Grid.ColumnDefinitions>

            <!-- ================= PRODUCTS ================= -->
            <ScrollViewer Grid.Column="0">
                <ItemsControl x:Name="ProductsItemsControl">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border Width="200"
                                    Margin="10"
                                    Padding="10"
                                    Background="{StaticResource CardBg}"
                                    CornerRadius="10">

                                <StackPanel>

                                    <!-- IMAGE -->
                                    <Image Height="120"
                                           Stretch="UniformToFill"
                                           Source="{Binding ImageSource}"/>

                                    <!-- NAME -->
                                    <TextBlock Text="{Binding ProductName}"
                                               Foreground="{StaticResource PrimaryText}"
                                               FontWeight="Bold"
                                               Margin="0,10,0,0"/>

                                    <!-- PRICE -->
                                    <TextBlock Text="{Binding Price, StringFormat=Rs. {0}}"
                                               Foreground="{StaticResource SecondaryText}"/>

                                    <!-- STATUS -->
                                    <TextBlock Text="{Binding Availability}"
                                               Foreground="{StaticResource Success}"/>

                                    <!-- ADD TO CART -->
                                    <Button Content="Add to Cart"
                                            Margin="0,10,0,0"
                                            Background="{StaticResource PrimaryBlue}"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Tag="{Binding}"
                                            Click="AddToCartClick"/>

                                </StackPanel>

                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>
            </ScrollViewer>

            <!-- ================= CART ================= -->
            <Border Grid.Column="1"
        Background="{StaticResource CartPanelBg}"
        Padding="15"
        CornerRadius="10">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- TITLE -->
                    <TextBlock Text="Your Cart"
                   Foreground="{StaticResource PrimaryText}"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

                    <!-- SCROLLABLE CART ITEMS -->
                    <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">

                        <ItemsControl Name="CartItemsControl">

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>

                                    <Border Background="{StaticResource CartItemBg}"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0,0,0,10">

                                        <!-- (KEEP YOUR EXISTING ITEM TEMPLATE EXACT SAME) -->

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>

                                            <!-- PRODUCT INFO -->
                                            <StackPanel Grid.Row="0" Grid.Column="0">

                                                <TextBlock Text="{Binding Product.ProductName}"
                                               Foreground="{StaticResource PrimaryText}"
                                               FontWeight="SemiBold"
                                               FontSize="13"/>

                                                <TextBlock Text="{Binding Product.Price, StringFormat=Rs. {0}}"
                                               Foreground="{StaticResource SecondaryText}"
                                               FontSize="12"
                                               Margin="0,3,0,0"/>

                                            </StackPanel>

                                            <!-- REMOVE -->
                                            <Button Content="✕"
                                                    Grid.Row="0"
                                                    Grid.Column="1"
                                                    Width="22"
                                                    Height="22"
                                                    Background="{StaticResource Danger}"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Tag="{Binding}"
                                                    Click="RemoveFromCartClick"/>   

                                            <!-- QUANTITY -->
                                            <Border Grid.Row="1"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="2"
                                                    Margin="0,10,0,0"
                                                    Background="#0F172A"
                                                    CornerRadius="6"
                                                    Padding="6">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Button Content="−"
                                                            Width="25"
                                                            Height="25"
                                                            Click="DecreaseQuantityClick"
                                                            Tag="{Binding}"
                                                            Background="{StaticResource HoverBg}"
                                                            Foreground="{StaticResource PrimaryText}"
                                                            BorderThickness="0"/>       

                                                    <TextBlock Text="{Binding Quantity}"
                                                   Grid.Column="1"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource PrimaryText}"
                                                   FontWeight="Bold"/>

                                                    <Button Content="+"
                                                Grid.Column="2"
                                                Width="25"
                                                Height="25"
                                                Click="IncreaseQuantityClick"
                                                Tag="{Binding}"
                                                Background="{StaticResource HoverBg}"
                                                Foreground="{StaticResource PrimaryText}"
                                                BorderThickness="0"/>

                                                </Grid>

                                            </Border>

                                        </Grid>

                                    </Border>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </ScrollViewer>

                    <!-- TOTAL (fixed at bottom section) -->
                    <Border Grid.Row="2"
                Background="{StaticResource CartSummaryBg}"
                Padding="12"
                Margin="0,10,0,0"
                CornerRadius="8">

                        <StackPanel>
                            <TextBlock Text="Total"
                           Foreground="{StaticResource SecondaryText}"
                           FontSize="12"/>

                            <TextBlock Name="TotalText"
                           Text="Rs. 0"
                           Foreground="{StaticResource PrimaryText}"
                           FontSize="18"
                           FontWeight="Bold"/>
                        </StackPanel>

                    </Border>

                    <!-- CHECKOUT (always visible, fixed bottom) -->
                    <Button Grid.Row="3"
                Content="Checkout"
                Margin="0,15,0,0"
                Background="{StaticResource PrimaryBlue}"
                Foreground="White"
                BorderThickness="0"
                Padding="10"
                Cursor="Hand"/>

                </Grid>

            </Border>

        </Grid>

    </Grid>
</Page>

