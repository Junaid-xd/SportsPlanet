<Page x:Class="SportsPlanet.Views.Dashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SportsPlanet.Views"
      xmlns:components="clr-namespace:SportsPlanet.Components"
      Title="Dashboard"
      Loaded="PageLoaded">

    <Grid Background="{StaticResource PrimaryBg}">

        <!-- MAIN -->
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <components:Header x:Name="HeaderControl"/>

            <!-- CONTENT -->
            <Grid Grid.Row="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="0*" x:Name="CartColumn"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE -->
                <Grid Grid.Column="0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- FILTERS (ADDED ONLY THIS PART) -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="10">

                        <Button Content="All"
                                Margin="5"
                                Padding="10,5"
                                Click="FilterAllClick"/>

                        <Button Content="New Arrivals"
                                Margin="5"
                                Padding="10,5"
                                Click="FilterNewClick"/>

                        <Button Content="Bats"
                                Margin="5"
                                Padding="10,5"
                                Click="FilterBatsClick"/>

                        <Button Content="Balls"
                                Margin="5"
                                Padding="10,5"
                                Click="FilterBallsClick"/>

                        <Button Content="Badminton"
                                Margin="5"
                                Padding="10,5"
                                Click="FilterBadmintonClick"/>

                        <Button Content="Kits"
                                Margin="5"
                                Padding="10,5"
                                Click="FilterKitsClick"/>

                    </StackPanel>

                    <!-- PRODUCTS -->
                    <ScrollViewer Grid.Row="1">
                        <ItemsControl Name="ProductsItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="200"
                                            Margin="10"
                                            Padding="10"
                                            Background="{StaticResource CardBg}"
                                            BorderBrush="#99FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="5">

                                        <StackPanel>
                                            <Image Height="120"
                                                   Stretch="UniformToFill"
                                                   Source="{Binding ImgPath}"/>

                                            <TextBlock Text="{Binding ProductName}"
                                                       Foreground="{StaticResource PrimaryText}"
                                                       FontWeight="Bold"
                                                       Margin="0,10,0,0"/>

                                            <TextBlock Text="{Binding Price, StringFormat=Rs. {0}}"
                                                       Foreground="{StaticResource SecondaryText}"/>

                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="In Stock"/>
                                                        <Setter Property="Foreground" Value="LightGreen"/>

                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Quantity}" Value="0">
                                                                <Setter Property="Text" Value="Out of Stock"/>
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <Button Content="Add to Cart"
                                                    Margin="0,10,0,0"
                                                    Background="{StaticResource PrimaryBlue}"
                                                    Foreground="{StaticResource OnPrimaryText}"
                                                    BorderThickness="0"
                                                    Tag="{Binding}"
                                                    Click="AddToCartClick">

                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Quantity}" Value="0">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>

                                            </Button>

                                        </StackPanel>

                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                </Grid>

                <!-- CART (UNCHANGED) -->
                <Border Grid.Column="1"
                        Background="{StaticResource CartPanelBg}"
                        Padding="15"
                        CornerRadius="10">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Your Cart"
                                   Foreground="{StaticResource PrimaryText}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">

                            <ItemsControl Name="CartItemsControl">

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <Border Background="{StaticResource CartItemBg}"
                                                CornerRadius="8"
                                                Padding="10"
                                                Margin="0,0,0,10">

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Grid.RowDefinitions>
                                                    <RowDefinition/>
                                                    <RowDefinition/>
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0" Grid.Column="0">

                                                    <TextBlock Text="{Binding Product.ProductName}"
                                                               Foreground="{StaticResource PrimaryText}"
                                                               Width="300"/>

                                                    <TextBlock Text="{Binding Product.Price, StringFormat=Rs. {0}}"
                                                               Foreground="{StaticResource SecondaryText}"/>

                                                </StackPanel>

                                                <Button Content="✕"
                                                        Grid.Row="0"
                                                        Grid.Column="1"
                                                        Width="22"
                                                        Height="22"
                                                        Background="{StaticResource Danger}"
                                                        Foreground="{StaticResource OnPrimaryText}"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Tag="{Binding}"
                                                        Click="RemoveFromCartClick"/>

                                                <Border Grid.Row="1"
                                                        Grid.Column="0"
                                                        Grid.ColumnSpan="2"
                                                        Margin="0,10,0,0"
                                                        Background="{StaticResource InputBg}"
                                                        CornerRadius="6"
                                                        Padding="6">

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Button Content="−"
                                                                Width="25"
                                                                Height="25"
                                                                Click="DecreaseQuantityClick"
                                                                Tag="{Binding}"
                                                                Background="{StaticResource HoverBg}"
                                                                Foreground="{StaticResource PrimaryText}"
                                                                BorderThickness="0"/>

                                                        <TextBlock Text="{Binding Quantity}"
                                                                   Grid.Column="1"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{StaticResource PrimaryText}"
                                                                   FontWeight="Bold"/>

                                                        <Button Content="+"
                                                                Grid.Column="2"
                                                                Width="25"
                                                                Height="25"
                                                                Click="IncreaseQuantityClick"
                                                                Tag="{Binding}"
                                                                Background="{StaticResource HoverBg}"
                                                                Foreground="{StaticResource PrimaryText}"
                                                                BorderThickness="0"/>

                                                    </Grid>

                                                </Border>

                                            </Grid>

                                        </Border>

                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>

                            </ItemsControl>

                        </ScrollViewer>

                        <Border Grid.Row="2"
                                Background="{StaticResource CartSummaryBg}"
                                Padding="12"
                                Margin="0,10,0,0"
                                CornerRadius="8">

                            <StackPanel>
                                <TextBlock Text="Total"
                                           Foreground="{StaticResource SecondaryText}"
                                           FontSize="12"/>

                                <TextBlock Name="TotalText"
                                           Text="Rs. 0"
                                           Foreground="{StaticResource PrimaryText}"
                                           FontSize="18"
                                           FontWeight="Bold"/>
                            </StackPanel>

                        </Border>

                        <Button Grid.Row="3"
                                Content="Checkout"
                                Margin="0,15,0,0"
                                Background="{StaticResource PrimaryBlue}"
                                Foreground="{StaticResource OnPrimaryText}"
                                BorderThickness="0"
                                Padding="10"
                                Cursor="Hand"
                                Click="HandleCheckout"/>

                    </Grid>

                </Border>

            </Grid>

        </Grid>

        <!-- CHECKOUT OVERLAY (UNCHANGED) -->
        <Grid x:Name="CheckoutOverlay"
              Background="{StaticResource OverlayBg}"
              Visibility="Collapsed"
              Panel.ZIndex="999">

            <Border Width="650"
                    MaxWidth="700"
                    BorderBrush="#FFFFFF"
                    BorderThickness="2"
                    Padding="25"
                    Background="{StaticResource CardBg}"
                    CornerRadius="5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel>

                    <TextBlock Text="Checkout"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryText}"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Review your order and complete purchase"
                               Foreground="{StaticResource SecondaryText}"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,20"/>

                    <Border Background="{StaticResource PrimaryBg}"
                            Padding="10"
                            CornerRadius="8">

                        <StackPanel>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Product"
                                           Foreground="{StaticResource MutedText}"/>
                                <TextBlock Text="Qty"
                                           Grid.Column="1"
                                           Foreground="{StaticResource MutedText}"/>
                                <TextBlock Text="Price"
                                           Grid.Column="2"
                                           Foreground="{StaticResource MutedText}"/>
                            </Grid>

                            <ScrollViewer MaxHeight="180"
                                          VerticalScrollBarVisibility="Auto">

                                <ItemsControl Name="CheckoutItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding Product.ProductName}"
                                                           Foreground="{StaticResource PrimaryText}"/>

                                                <TextBlock Text="{Binding Quantity}"
                                                           Grid.Column="1"
                                                           Foreground="{StaticResource SecondaryText}"/>

                                                <TextBlock Text="{Binding Product.Price, StringFormat=Rs. {0}}"
                                                           Grid.Column="2"
                                                           Foreground="{StaticResource SecondaryText}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </ScrollViewer>

                        </StackPanel>
                    </Border>

                    <TextBlock Text="Shipping Address"
                               Foreground="{StaticResource MutedText}"
                               Margin="0,15,0,5"/>

                    <TextBox Name="AddressBox"
                             Height="40"
                             Padding="8"
                             Background="{StaticResource PrimaryBg}"
                             Foreground="{StaticResource PrimaryText}"
                             BorderBrush="#334155"
                             BorderThickness="1"/>

                    <TextBlock Text="Delivery Type"
                               Foreground="{StaticResource MutedText}"
                               Margin="0,15,0,5"/>

                    <ComboBox Name="DeliveryTypeBox"
                              Height="35"
                              Foreground="Black"
                              BorderBrush="#334155"
                              BorderThickness="1"
                              Padding="5"
                              SelectedIndex="0">

                        <ComboBoxItem Content="Standard"/>
                        <ComboBoxItem Content="Express"/>
                    </ComboBox>

                    <TextBlock Text="Payment Method"
                               Foreground="{StaticResource MutedText}"
                               Margin="0,15,0,5"/>

                    <ComboBox Name="PaymentBox"
                              Height="35"
                              Foreground="Black"
                              BorderBrush="#334155"
                              BorderThickness="1"
                              Padding="5"
                              SelectedIndex="0">

                        <ComboBoxItem Content="COD (Cash on Delivery)"/>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,20,0,0">

                        <Button Content="Cancel"
                                Width="90"
                                Height="35"
                                Margin="0,0,10,0"
                                Background="Transparent"
                                Foreground="{StaticResource SecondaryText}"
                                BorderBrush="#334155"
                                Click="CloseCheckout"/>

                        <Button Content="Confirm"
                                Width="110"
                                Height="35"
                                Background="{StaticResource PrimaryBlue}"
                                Foreground="{StaticResource OnPrimaryText}"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Click="ConfirmOrderClick"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Page>