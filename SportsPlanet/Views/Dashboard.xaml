

<Page x:Class="SportsPlanet.Views.Dashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SportsPlanet.Views"
      xmlns:components="clr-namespace:SportsPlanet.Components"
      Title="Dashboard"
      Loaded="PageLoaded">

    <Grid Background="{StaticResource PrimaryBg}">

        <!-- ================= MAIN CONTENT ================= -->
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- ================= HEADER ================= -->


            <components:Header x:Name="HeaderControl"/>


            <!-- ================= CONTENT ================= -->
            <Grid Grid.Row="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="0*" x:Name="CartColumn"/>
                </Grid.ColumnDefinitions>

                <!-- PRODUCTS -->
                <ScrollViewer Grid.Column="0">
                    <ItemsControl Name="ProductsItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="200"
                                        Margin="10"
                                        Padding="10"
                                        Background="{StaticResource CardBg}"
                                        CornerRadius="10">

                                    <StackPanel>
                                        <Image Height="120"
                                               Stretch="UniformToFill"
                                               Source="{Binding ImgPath}"/>

                                        <TextBlock Text="{Binding ProductName}"
                                                   Foreground="{StaticResource PrimaryText}"
                                                   FontWeight="Bold"
                                                   Margin="0,10,0,0"/>

                                        <TextBlock Text="{Binding Price, StringFormat=Rs. {0}}"
                                                   Foreground="{StaticResource SecondaryText}"/>

                                        <TextBlock Text="{Binding Availability}"
                                                   Foreground="{StaticResource Success}"/>

                                        <Button Content="Add to Cart"
                                                Margin="0,10,0,0"
                                                Background="{StaticResource PrimaryBlue}"
                                                Foreground="{StaticResource OnPrimaryText}"
                                                BorderThickness="0"
                                                Tag="{Binding}"
                                                Click="AddToCartClick"/>
                                    </StackPanel>

                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- CART -->
                <Border Grid.Column="1"
                        Background="{StaticResource CartPanelBg}"
                        Padding="15"
                        CornerRadius="10">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Your Cart"
                                   Foreground="{StaticResource PrimaryText}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">

                            <ItemsControl Name="CartItemsControl">

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <Border Background="{StaticResource CartItemBg}"
                                                CornerRadius="8"
                                                Padding="10"
                                                Margin="0,0,0,10">

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Grid.RowDefinitions>
                                                    <RowDefinition/>
                                                    <RowDefinition/>
                                                </Grid.RowDefinitions>

                                                <!-- PRODUCT INFO -->
                                                <StackPanel Grid.Row="0" Grid.Column="0">

                                                    <TextBlock Text="{Binding Product.ProductName}"
                                                               Foreground="{StaticResource PrimaryText}"
                                                               Width="300"/>

                                                    

                                                    <TextBlock Text="{Binding Product.Price, StringFormat=Rs. {0}}"
                                                               Foreground="{StaticResource SecondaryText}"/>

                                                </StackPanel>

                                                <!-- REMOVE -->
                                                <Button Content="✕"
                                                        Grid.Row="0"
                                                        Grid.Column="1"
                                                        Width="22"
                                                        Height="22"
                                                        Background="{StaticResource Danger}"
                                                        Foreground="{StaticResource OnPrimaryText}"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Tag="{Binding}"
                                                        Click="RemoveFromCartClick"/>

                                                <!-- QUANTITY -->
                                                <Border Grid.Row="1"
                                                        Grid.Column="0"
                                                        Grid.ColumnSpan="2"
                                                        Margin="0,10,0,0"
                                                        Background="{StaticResource InputBg}"
                                                        CornerRadius="6"
                                                        Padding="6">

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Button Content="−"
                                                                Width="25"
                                                                Height="25"
                                                                Click="DecreaseQuantityClick"
                                                                Tag="{Binding}"
                                                                Background="{StaticResource HoverBg}"
                                                                Foreground="{StaticResource PrimaryText}"
                                                                BorderThickness="0"/>

                                                        <TextBlock Text="{Binding Quantity}"
                                                                   Grid.Column="1"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{StaticResource PrimaryText}"
                                                                   FontWeight="Bold"/>

                                                        <Button Content="+"
                                                                Grid.Column="2"
                                                                Width="25"
                                                                Height="25"
                                                                Click="IncreaseQuantityClick"
                                                                Tag="{Binding}"
                                                                Background="{StaticResource HoverBg}"
                                                                Foreground="{StaticResource PrimaryText}"
                                                                BorderThickness="0"/>

                                                    </Grid>

                                                </Border>

                                            </Grid>

                                        </Border>

                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>

                            </ItemsControl>

                        </ScrollViewer>

                        <!-- TOTAL -->
                        <Border Grid.Row="2"
                                Background="{StaticResource CartSummaryBg}"
                                Padding="12"
                                Margin="0,10,0,0"
                                CornerRadius="8">

                            <StackPanel>
                                <TextBlock Text="Total"
                                           Foreground="{StaticResource SecondaryText}"
                                           FontSize="12"/>

                                <TextBlock Name="TotalText"
                                           Text="Rs. 0"
                                           Foreground="{StaticResource PrimaryText}"
                                           FontSize="18"
                                           FontWeight="Bold"/>
                            </StackPanel>

                        </Border>

                        <!-- CHECKOUT -->
                        <Button Grid.Row="3"
                                Content="Checkout"
                                Margin="0,15,0,0"
                                Background="{StaticResource PrimaryBlue}"
                                Foreground="{StaticResource OnPrimaryText}"
                                BorderThickness="0"
                                Padding="10"
                                Cursor="Hand"
                                Click="HandleCheckout"/>

                    </Grid>

                </Border>

            </Grid>

        </Grid>

        <!-- ================= OVERLAY ================= -->
        <Grid x:Name="CheckoutOverlay"
              Background="{StaticResource OverlayBg}"
              Visibility="Collapsed"
              Panel.ZIndex="999">

            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Width="500">

                <Border Background="{StaticResource CardBg}"
                        Padding="20"
                        CornerRadius="10">

                    <ScrollViewer>

                        <StackPanel>

                            <TextBlock Text="Checkout"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryText}"
                                       Margin="0,0,0,15"/>

                            <ItemsControl Name="CheckoutItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,5">
                                            <TextBlock Text="{Binding Product.ProductName}" Width="200"
                                                       Foreground="{StaticResource PrimaryText}"/>
                                            <TextBlock Text="{Binding Quantity}" Width="50"
                                                       Foreground="{StaticResource SecondaryText}"/>
                                            <TextBlock Text="{Binding Product.Price, StringFormat=Rs. {0}}"
                                                       Foreground="{StaticResource SecondaryText}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Shipping Address"
                                       Foreground="{StaticResource SecondaryText}"
                                       Margin="0,15,0,5"/>

                            <TextBox Name="AddressBox"
                                     Height="60"
                                     Background="{StaticResource InputBg}"
                                     Foreground="{StaticResource InputText}"/>

                            <TextBlock Text="Delivery Type"
                                       Foreground="{StaticResource SecondaryText}"
                                       Margin="0,15,0,5"/>

                            <ComboBox Name="DeliveryTypeBox"
                                      Background="{StaticResource InputBg}"
                                      Foreground="{StaticResource InputText}"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Standard"/>
                                <ComboBoxItem Content="Express"/>
                            </ComboBox>

                            <TextBlock Text="Payment Method"
                                       Foreground="{StaticResource SecondaryText}"
                                       Margin="0,15,0,5"/>

                            <ComboBox Name="PaymentBox"
                                      Background="{StaticResource InputBg}"
                                      Foreground="{StaticResource InputText}"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Cash on Delivery"/>
                                <ComboBoxItem Content="Card"/>
                            </ComboBox>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,20,0,0">

                                <Button Content="Cancel"
                                        Margin="0,0,10,0"
                                        Click="CloseCheckout"/>

                                <Button Content="Confirm Order"
                                        Background="{StaticResource PrimaryBlue}"
                                        Foreground="{StaticResource OnPrimaryText}"
                                        Click="ConfirmOrderClick"/>
                            </StackPanel>

                        </StackPanel>

                    </ScrollViewer>

                </Border>

            </Grid>

        </Grid>

    </Grid>
</Page>