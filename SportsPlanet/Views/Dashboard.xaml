<Page x:Class="SportsPlanet.Views.Dashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SportsPlanet.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Dashboard">

    <Grid Background="{StaticResource PrimaryBg}">

        <!-- ================= HEADER ================= -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource CardBg}" Padding="15">
            <DockPanel>

                <!-- BRAND -->
                <TextBlock Text="Sports Planet"
                           Foreground="{StaticResource PrimaryText}"
                           FontSize="20"
                           FontWeight="Bold"
                           DockPanel.Dock="Left"/>

                <!-- MENU -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Content="New Arrivals" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Bats" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Balls" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Badminton" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Kits" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Orders" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Cart" Style="{StaticResource MenuButtonStyle}"/>

                    <!-- ADMIN -->
                    <Button Content="Stats"
                            Style="{StaticResource MenuButtonStyle}"
                            Visibility="Collapsed"
                            x:Name="StatsBtn"/>

                    <Button Content="Manage Products"
                            Style="{StaticResource MenuButtonStyle}"
                            Visibility="Collapsed"
                            x:Name="ManageProductsBtn"/>

                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ================= CONTENT ================= -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0" x:Name="CartColumn"/>
            </Grid.ColumnDefinitions>

            <!-- ================= PRODUCTS ================= -->
            <ScrollViewer Grid.Column="0">
                <ItemsControl ItemsSource="{Binding Products}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border Width="200"
                                    Margin="10"
                                    Padding="10"
                                    Background="{StaticResource CardBg}"
                                    CornerRadius="10">

                                <StackPanel>

                                    <!-- IMAGE -->
                                    <Image Height="120"
                                           Stretch="UniformToFill"
                                           Source="{Binding ImageSource}"/>

                                    <!-- NAME -->
                                    <TextBlock Text="{Binding ProductName}"
                                               Foreground="{StaticResource PrimaryText}"
                                               FontWeight="Bold"
                                               Margin="0,10,0,0"/>

                                    <!-- PRICE -->
                                    <TextBlock Text="{Binding Price, StringFormat=Rs. {0}}"
                                               Foreground="{StaticResource SecondaryText}"/>

                                    <!-- STATUS -->
                                    <TextBlock Text="{Binding Availability}"
                                               Foreground="{StaticResource Success}"/>

                                    <!-- ADD TO CART -->
                                    <Button Content="Add to Cart"
                                            Margin="0,10,0,0"
                                            Background="{StaticResource PrimaryBlue}"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"/>

                                </StackPanel>

                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>
            </ScrollViewer>

            <!-- ================= CART ================= -->
            <Border Grid.Column="1"
                    Background="{StaticResource CardBg}"
                    Padding="15">

                <StackPanel>

                    <TextBlock Text="Your Cart"
                               Foreground="{StaticResource PrimaryText}"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <!-- CART ITEMS -->
                    <ItemsControl ItemsSource="{Binding CartItems}"
                                  Margin="0,10,0,0"/>

                    <!-- CHECKOUT -->
                    <Button Content="Checkout"
                            Margin="0,20,0,0"
                            Background="{StaticResource PrimaryBlue}"
                            Foreground="White"
                            BorderThickness="0"/>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>
</Page>

