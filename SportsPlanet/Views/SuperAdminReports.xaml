<Page x:Class="SportsPlanet.Views.SuperAdminReports"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"      xmlns:components="clr-namespace:SportsPlanet.Components"
      Title="SuperAdminReports">

    <Grid Background="{StaticResource PrimaryBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <components:Header x:Name="HeaderControl"/>

        <!-- KPI CARDS -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="20">

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Today's Orders" Style="{StaticResource KpiTextTitle}"/>
                    <TextBlock Text="{Binding TodayOrders}" Style="{StaticResource KpiTextValue}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Pending" Style="{StaticResource KpiTextTitle}"/>
                    <TextBlock Text="{Binding PendingOrders}" Style="{StaticResource KpiTextValue}" FontSize="20"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Dispatched" Style="{StaticResource KpiTextTitle}"/>
                    <TextBlock Text="{Binding DispatchedOrders}" FontSize="20" Style="{StaticResource KpiTextValue}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Total Users" Style="{StaticResource KpiTextTitle}"/>
                    <TextBlock Text="{Binding TotalUsers}" FontSize="20" Style="{StaticResource KpiTextValue}"/>
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- CHARTS -->
        <Grid Grid.Row="2" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

             <!--WEEKLY BAR--> 
            <Border Style="{StaticResource CardStyle}" Margin="10">
                <StackPanel>

                    <TextBlock Text="Weekly Orders"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="10"
                               Foreground="White"/>

                    <lvc:CartesianChart
                        Series="{Binding WeeklySeries}"
                        XAxes="{Binding XAxes}"
                        YAxes="{Binding YAxes}"
                        Height="300"/>

                </StackPanel>
            </Border>

             <!--PIE--> 
            <Border Style="{StaticResource CardStyle}" Margin="10" Grid.Column="1">
                <StackPanel>

                    <TextBlock Text="Order Status Distribution"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="10"
                               Foreground="White"/>

                    <lvc:PieChart
                        Series="{Binding StatusSeries}"
                        LegendPosition="Bottom"
                        Height="300"/>

                </StackPanel>
            </Border>

        </Grid>

    </Grid>
</Page>
