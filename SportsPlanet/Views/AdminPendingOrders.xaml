<Page x:Class="SportsPlanet.Views.AdminPendingOrders"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:components="clr-namespace:SportsPlanet.Components"
      xmlns:conv="clr-namespace:SportsPlanet.Converters"
      Title="AdminDispatchOrders">

    <!-- RESOURCES -->
    <Page.Resources>
        <conv:UnixToDateConverter x:Key="UnixToDateConverter"/>
    </Page.Resources>

    <!-- ROOT -->
    <Grid>

        <!-- MAIN CONTENT -->
        <Grid Background="{StaticResource PrimaryBg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <components:Header x:Name="HeaderControl"/>

            <!-- ORDERS -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled">

                <Grid HorizontalAlignment="Center">
                    <ItemsControl x:Name="OrdersItemsControl">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>

                            <DataTemplate>

                                <Border Width="360"
                                        Margin="12"
                                        Padding="16"
                                        CornerRadius="10"
                                        Background="{StaticResource CardBg}"
                                        BorderBrush="#2D3748"
                                        BorderThickness="1">

                                    <StackPanel>

                                        <!-- CUSTOMER -->
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Customer: "
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SecondaryText}"/>
                                                                        <TextBlock Text="{Binding User.Email}"
                                                       Foreground="{StaticResource PrimaryText}"/>
                                        </StackPanel>

                                        <!-- DATE -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Date: "
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SecondaryText}"/>
                                            <TextBlock Foreground="{StaticResource PrimaryText}">
                                                <TextBlock.Text>
                                                    <Binding Path="CreatedAt"
                                                             Converter="{StaticResource UnixToDateConverter}"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- ADDRESS -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Address: "
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SecondaryText}"/>
                                            <TextBlock Text="{Binding Address}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource PrimaryText}"
                                                       Width="240"/>
                                        </StackPanel>

                                        <!-- DELIVERY -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Delivery: "
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SecondaryText}"/>
                                            <TextBlock Text="{Binding DeliveryType}"
                                                       Foreground="{StaticResource PrimaryText}"/>
                                        </StackPanel>

                                        <!-- TOTAL -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Total: "
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SecondaryText}"/>
                                            <TextBlock Text="{Binding TotalAmount, StringFormat=Rs. {0}}"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource PrimaryText}"/>
                                        </StackPanel>

                                        <!-- STATUS -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,10">
                                            <TextBlock Text="Status: "
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SecondaryText}"/>
                                            <TextBlock Text="{Binding Status}"
                                                       Foreground="Orange"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <!-- ACTIONS -->
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Right">

                                            <Button Content="View"
                                                    Margin="0,0,8,0"
                                                    Padding="10,5"
                                                    Background="{StaticResource HoverBg}"
                                                    Foreground="{StaticResource PrimaryText}"
                                                    BorderThickness="0"
                                                    Tag="{Binding}"
                                                    Click="ViewDetailsClick"/>

                                            <Button Content="Dispatch"
                                                    Padding="10,5"
                                                    Background="{StaticResource PrimaryBlue}"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    Tag="{Binding}"
                                                    Click="DispatchOrderClick"/>

                                        </StackPanel>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                </Grid>

            </ScrollViewer>
        </Grid>

        <!-- DETAILS POPUP -->
        <Grid x:Name="DetailsOverlay"
              Background="{StaticResource OverlayBg}"
              Visibility="Collapsed"
              Panel.ZIndex="999">

            <Border Width="600"
                    Padding="20"
                    Background="{StaticResource CardBg}"
                    CornerRadius="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel>

                    <!-- TITLE -->
                    <TextBlock Text="Order Details"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryText}"
                               HorizontalAlignment="Center"/>

                    <!-- INFO -->
                    <TextBlock x:Name="DetailsInfoText"
                               Margin="0,10,0,10"
                               Foreground="{StaticResource SecondaryText}"/>

                    <!-- ITEMS -->
                    <ScrollViewer MaxHeight="200">
                        <ItemsControl x:Name="DetailsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Product.ProductName}"
                                                   Foreground="{StaticResource PrimaryText}"/>

                                        <TextBlock Text="{Binding Quantity}"
                                                   Grid.Column="1"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource SecondaryText}"/>

                                        <TextBlock Text="{Binding Price, StringFormat=Rs. {0}}"
                                                   Grid.Column="2"
                                                   Foreground="{StaticResource SecondaryText}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- CLOSE -->
                    <Button Content="Close"
                            Margin="0,15,0,0"
                            Width="100"
                            HorizontalAlignment="Right"
                            Background="{StaticResource PrimaryBlue}"
                            Foreground="White"
                            Click="CloseDetails"/>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>
</Page>
