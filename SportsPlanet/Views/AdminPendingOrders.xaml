<Page x:Class="SportsPlanet.Views.AdminPendingOrders"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:components="clr-namespace:SportsPlanet.Components"
      xmlns:conv="clr-namespace:SportsPlanet.Converters"
      Title="AdminDispatchOrders">

    <!-- RESOURCES -->
    <Page.Resources>
        <conv:UnixToDateConverter x:Key="UnixToDateConverter"/>
    </Page.Resources>

    <!-- ROOT -->
    <Grid>

        <!-- TOAST -->
        <Border x:Name="Toast"
        Background="#111827"
        CornerRadius="6"
        Padding="12"
        HorizontalAlignment="Center"
        VerticalAlignment="Top"
        Margin="0,20,0,0"
        Visibility="Collapsed"
        Panel.ZIndex="9999">

            <TextBlock x:Name="ToastText"
               Foreground="White"
               FontWeight="SemiBold"/>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Background="{StaticResource PrimaryBg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>


            <!-- HEADER -->
            <components:Header x:Name="HeaderControl"/>


                    



            <!-- ORDERS -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled">

                <Grid HorizontalAlignment="Center">
                    <ItemsControl x:Name="OrdersItemsControl">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>

                            <DataTemplate>

                                <Border Width="360"
                                        Margin="12"
                                        Padding="16"
                                        CornerRadius="10"
                                        Background="{StaticResource CardBg}"
                                        BorderBrush="#2D3748"
                                        BorderThickness="1">

                                    <StackPanel>

                                        <!-- CUSTOMER -->
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Customer: "
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SecondaryText}"/>
                                                                        <TextBlock Text="{Binding User.Email}"
                                                       Foreground="{StaticResource PrimaryText}"/>
                                        </StackPanel>

                                        <!-- DATE -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Date: "
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SecondaryText}"/>
                                            <TextBlock Foreground="{StaticResource PrimaryText}">
                                                <TextBlock.Text>
                                                    <Binding Path="CreatedAt"
                                                             Converter="{StaticResource UnixToDateConverter}"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- ADDRESS -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Address: "
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SecondaryText}"/>
                                            <TextBlock Text="{Binding Address}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource PrimaryText}"
                                                       Width="240"/>
                                        </StackPanel>

                                        <!-- DELIVERY -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Delivery: "
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SecondaryText}"/>
                                            <TextBlock Text="{Binding DeliveryType}"
                                                       Foreground="{StaticResource PrimaryText}"/>
                                        </StackPanel>

                                        <!-- TOTAL -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Total: "
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SecondaryText}"/>
                                            <TextBlock Text="{Binding TotalAmount, StringFormat=Rs. {0}}"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource PrimaryText}"/>
                                        </StackPanel>

                                        <!-- STATUS -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,10">
                                            <TextBlock Text="Status: "
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SecondaryText}"/>
                                            <TextBlock Text="{Binding Status}"
                                                       Foreground="Orange"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <!-- ACTIONS -->
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Right">

                                            <Button Content="View"
                                                    Margin="0,0,8,0"
                                                    BorderThickness="0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Tag="{Binding}"
                                                    Click="ViewDetailsClick"/>

                                            <Button Content="Dispatch"
                                                    Tag="{Binding}"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Click="DispatchOrderClick"/>

                                        </StackPanel>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                </Grid>

            </ScrollViewer>
        </Grid>

        <!-- DETAILS POPUP -->
        <Grid x:Name="DetailsOverlay"
              Background="{StaticResource OverlayBg}"
              Visibility="Collapsed"
              Panel.ZIndex="999">

            <Border Width="600"
                    Padding="20"
                    Background="{StaticResource CardBg}"
                    CornerRadius="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel>

                    <!-- TITLE -->
                    <TextBlock Text="Order Details"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryText}"
                               HorizontalAlignment="Center"/>

                    <!-- INFO -->

                    <Border Background="{StaticResource HoverBg}"
                             CornerRadius="8"
                             Padding="10"
                             Margin="0,10,0,10">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Customer -->
                            <TextBlock Text="Customer:"
                                        Foreground="{StaticResource SecondaryText}"
                                        FontWeight="SemiBold"/>
                            <TextBlock x:Name="CustomerText"
                                        Grid.Column="1"
                                        Foreground="{StaticResource PrimaryText}"/>

                            <!-- Address -->
                            <TextBlock Text="Address:"
                                        Grid.Row="1"
                                        Foreground="{StaticResource SecondaryText}"
                                        FontWeight="SemiBold"
                                        Margin="0,6,0,0"/>
                            
                            <TextBlock x:Name="AddressText"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Foreground="{StaticResource PrimaryText}"
                                        Margin="0,6,0,0"
                                        TextWrapping="Wrap"/>

                            <!-- Delivery -->
                            <TextBlock Text="Delivery:"
                                        Grid.Row="2"
                                        Foreground="{StaticResource SecondaryText}"
                                        FontWeight="SemiBold"
                                        Margin="0,6,0,0"/>
                            
                            <TextBlock x:Name="DeliveryText"
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Foreground="{StaticResource PrimaryText}"
                                        Margin="0,6,0,0"/>

                            <!-- Total -->
                            <TextBlock Text="Total:"
                                        Grid.Row="3"
                                        Foreground="{StaticResource SecondaryText}"
                                        FontWeight="SemiBold"
                                        Margin="0,6,0,0"/>
                            
                            <TextBlock x:Name="TotalText"
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        Foreground="{StaticResource PrimaryText}"
                                        FontWeight="Bold"
                                        Margin="0,6,0,0"/>
                        </Grid>

                    </Border>

                    <!-- ITEMS -->
                    <ScrollViewer MaxHeight="200"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="DetailsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource HoverBg}"
                                            CornerRadius="6"
                                            Padding="8"
                                            Margin="0,4">

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- PRODUCT NAME -->
                                            <TextBlock Text="{Binding Product.ProductName}"
                                                       Foreground="{StaticResource PrimaryText}"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"/>

                                            <!-- QUANTITY -->
                                            <Border Grid.Column="1"
                                                    Background="{StaticResource InputBg}"
                                                    CornerRadius="5"
                                                    Padding="4"
                                                    HorizontalAlignment="Center">

                                                <TextBlock Text="{Binding Quantity}"
                                                        Foreground="{StaticResource PrimaryText}"
                                                        FontWeight="SemiBold"
                                                        HorizontalAlignment="Center"/>
                                            </Border>

                                            <!-- PRICE -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Price, StringFormat=Rs. {0}}"
                                                       Foreground="{StaticResource PrimaryText}"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>

                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- CLOSE -->
                    <Button Content="Close"
                            Margin="0,15,0,0"
                            Width="100" 
                            HorizontalAlignment="Right"
                            
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="CloseDetails"/>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>
</Page>
