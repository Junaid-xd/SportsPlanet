<Page x:Class="SportsPlanet.Views.SignupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SportsPlanet.Views"
      mc:Ignorable="d"
      Title="SignupPage">

    <Grid Background="{StaticResource PrimaryBg}">

        <!-- Center container that stretches properly -->
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Margin="20">

            <Border Padding="25"
                    Background="{StaticResource CardBg}"
                    CornerRadius="12"
                    Width="380"
                    MinWidth="300"
                    MaxWidth="420"
                    HorizontalAlignment="Center">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel>

                        <!-- Title -->
                        <TextBlock Text="Create Account"
                                   Foreground="{StaticResource PrimaryText}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Join Sports Planet"
                                   Foreground="{StaticResource SecondaryText}"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,20"/>

                        <!-- Name -->
                        <TextBlock Text="Full Name"
                                   Foreground="{StaticResource MutedText}"
                                   Margin="0,5"/>

                        <TextBox Height="35"
                                 Background="{StaticResource CardBg}"
                                 Foreground="{StaticResource PrimaryText}"
                                 BorderBrush="#334155"
                                 Padding="8"
                                 Cursor="IBeam"
                                 HorizontalAlignment="Stretch"/>

                        <!-- Email -->
                        <TextBlock Text="Email"
                                   Foreground="{StaticResource MutedText}"
                                   Margin="0,15,0,5"/>

                        <TextBox Height="35"
                                 Background="{StaticResource CardBg}"
                                 Foreground="{StaticResource PrimaryText}"
                                 BorderBrush="#334155"
                                 Padding="8"
                                 Cursor="IBeam"
                                 HorizontalAlignment="Stretch"/>

                        <!-- Password -->
                        <TextBlock Text="Password"
                                   Foreground="{StaticResource MutedText}"
                                   Margin="0,15,0,5"/>

                        <PasswordBox Height="35"
                                     Background="{StaticResource CardBg}"
                                     Foreground="{StaticResource PrimaryText}"
                                     BorderBrush="#334155"
                                     Padding="8"
                                     HorizontalAlignment="Stretch"/>

                        <!-- Signup Button -->
                        <Button Content="Create Account"
                                Height="40"
                                Margin="0,20,0,0"
                                Background="{StaticResource PrimaryBlue}"
                                Foreground="{StaticResource PrimaryText}"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                HorizontalAlignment="Stretch"/>

                        <!-- Footer -->
                        <TextBlock Text="Already have an account? Login"
                                   Foreground="{StaticResource PrimaryBlue}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,15,0,0"
                                   Cursor="Hand"
                                   MouseLeftButtonUp="goToLoginPage"/>

                    </StackPanel>

                </ScrollViewer>

            </Border>
        </Grid>

    </Grid>

</Page>