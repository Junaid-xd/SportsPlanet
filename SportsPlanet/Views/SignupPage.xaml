<Page x:Class="SportsPlanet.Views.SignupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SportsPlanet.Views"
      mc:Ignorable="d"
      Title="SignupPage">

    <Grid Background="{StaticResource PrimaryBg}">

        <!-- Center container that stretches properly -->
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Margin="20">

            <Border Padding="25"
                    Background="{StaticResource CardBg}"
                    CornerRadius="12"
                    Width="380"
                    MinWidth="300"
                    MaxWidth="420"
                    HorizontalAlignment="Center">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel>

                        <!-- Title -->
                        <TextBlock Text="Create Account"
                                   Foreground="{StaticResource PrimaryText}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Join Sports Planet"
                                   Foreground="{StaticResource SecondaryText}"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,20"/>

                        <Border x:Name="SuccessBox"
                                Background="#DCFCE7"
                                BorderBrush="#22C55E"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,0,0,15"
                                Visibility="Collapsed">

                            <TextBlock x:Name="SuccessText"
                                       Text="Account created successfully!"
                                       Foreground="#166534"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <!-- Name -->
                        <TextBlock Text="Full Name"
                                   Foreground="{StaticResource MutedText}"
                                   Margin="0,5"/>

                        <TextBox Height="35"
                                 Background="{StaticResource CardBg}"
                                 Foreground="{StaticResource PrimaryText}"
                                 BorderBrush="#334155"
                                 Padding="8"
                                 Cursor="IBeam"
                                 HorizontalAlignment="Stretch"
                                 Name="T1"/>

                        <TextBlock x:Name="NameError"
                                   Foreground="#EF4444"
                                   FontSize="11"
                                   Margin="5,3,0,0"/>

                        <!-- Email -->
                        <TextBlock Text="Email"
                                   Foreground="{StaticResource MutedText}"
                                   Margin="0,15,0,5"/>

                        <TextBox Height="35"
                                 Background="{StaticResource CardBg}"
                                 Foreground="{StaticResource PrimaryText}"
                                 BorderBrush="#334155"
                                 Padding="8"
                                 Cursor="IBeam"
                                 HorizontalAlignment="Stretch"
                                 Name="T2"/>

                        <TextBlock x:Name="EmailError"
                                   Foreground="#EF4444"
                                   FontSize="11"
                                   Margin="5,3,0,0"/>

                        <!-- Password -->
                        <TextBlock Text="Password"
                                   Foreground="{StaticResource MutedText}"
                                   Margin="0,15,0,5"/>

                        <TextBox Height="35"
                                Background="{StaticResource CardBg}"
                                Foreground="{StaticResource PrimaryText}"
                                BorderBrush="#334155"
                                Padding="8"
                                Cursor="IBeam"
                                HorizontalAlignment="Stretch"
                                Name="T3"/>

                        <TextBlock x:Name="PasswordError"
                                   Foreground="#EF4444"
                                   FontSize="11"
                                   Margin="5,3,0,0"/>

                        
                        <!-- Confirm Password -->
                        <TextBlock Text="Confirm Password"
                                   Foreground="{StaticResource MutedText}"
                                   Margin="0,15,0,5"/>

                        <TextBox Height="35"
                                Background="{StaticResource CardBg}"
                                Foreground="{StaticResource PrimaryText}"
                                BorderBrush="#334155"
                                Padding="8"
                                Cursor="IBeam"
                                HorizontalAlignment="Stretch"
                                Name="T4"/>

                        <TextBlock x:Name="ConfirmPasswordError"
                                   Foreground="#EF4444"
                                   FontSize="11"
                                   Margin="5,3,0,0"/>


                       

                        <!-- Signup Button -->
                        <Button Content="Create Account"
                                Height="40"
                                Margin="0,20,0,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                HorizontalAlignment="Stretch"
                                Click="SignupButtonClick"/>
                       

                        <!-- Footer -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>

                            <TextBlock 
                                Grid.Column="0"
                                Text="Already have an account?"
                                Foreground="{StaticResource PrimaryBlue}"
                                FontSize="12"
                                HorizontalAlignment="Center"
                                Margin="0,15,0,0"
                                Cursor="Hand"
                                MouseLeftButtonUp="GoToLoginPage"/>

                            <TextBlock 
                                Grid.Column="1"
                                Text="Browse Products"
                                Foreground="{StaticResource PrimaryBlue}"
                                FontSize="12"
                                HorizontalAlignment="Center"
                                Margin="0,15,0,0"
                                Cursor="Hand"
                                MouseLeftButtonUp="GoToDashboard"/>
                        </Grid>

                    </StackPanel>

                </ScrollViewer>

            </Border>
        </Grid>

    </Grid>

</Page>