<Page x:Class="SportsPlanet.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SportsPlanet.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <Grid Background="{StaticResource PrimaryBg}">

        <!-- Center Card -->
        <Border Width="350"
            Padding="25"
            Background="{StaticResource CardBg}"
            CornerRadius="12"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <StackPanel>

                <!-- Title -->
                <TextBlock Text="Sports Planet"
                       Foreground="{StaticResource PrimaryText}"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

                <TextBlock Text="Login to your account"
                       Foreground="{StaticResource SecondaryText}"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,20"/>

                <!-- Email -->
                <TextBlock Text="Email"
                       Foreground="{StaticResource MutedText}"
                       Margin="0,5"/>

                <TextBox Height="35"
                     Background="{StaticResource PrimaryBg}"
                     Foreground="{StaticResource PrimaryText}"
                     BorderBrush="#334155"
                     Padding="8"
                     BorderThickness="1"
                         Name="T1"/>

                <TextBlock x:Name="EmailError"
                           Text=""
                           Foreground="#EF4444"
                           FontSize="11"
                           Margin="5,3,0,0"/>

                <!-- Password -->
                <TextBlock Text="Password"
                       Foreground="{StaticResource MutedText}"
                       Margin="0,15,0,5"/>

                <PasswordBox
                        Height="35"
                        Background="{StaticResource PrimaryBg}"
                        Foreground="{StaticResource PrimaryText}"
                        BorderBrush="#334155"
                        Padding="8"
                        BorderThickness="1"
                        Name="T2"/>

                <TextBlock x:Name="PasswordError"
                           Text=""
                           Foreground="#EF4444"
                           FontSize="11"
                           Margin="5,3,0,0"/>

                

                <!-- Login Button -->
                <Button Content="Login"
                    Height="40"
                    Margin="0,20,0,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                        Click="LoginClick"/>

               

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <TextBlock 
                        Grid.Column="0"
                        Text="Create new account?"
                        Foreground="{StaticResource PrimaryBlue}"
                        FontSize="10"
                        HorizontalAlignment="Center"
                        Margin="0,15,0,0"
                        Cursor="Hand"
                        MouseLeftButtonUp="goToSignupPage"/>
                    
                    <TextBlock 
                        Grid.Column="1"
                        Text="Browse Products"
                        Foreground="{StaticResource PrimaryBlue}"
                        FontSize="10"
                        HorizontalAlignment="Center"
                        Margin="0,15,0,0"
                        Cursor="Hand"
                        MouseLeftButtonUp="goToDashboardPage"/>

                    <TextBlock 
                        Grid.Column="2"
                        Text="Forgot password?"
                        Foreground="{StaticResource PrimaryBlue}"
                        FontSize="10"
                        HorizontalAlignment="Center"
                        Margin="0,15,0,0"
                        Cursor="Hand"/>


                </Grid>

                

            </StackPanel>
        </Border>

    </Grid>
</Page>
