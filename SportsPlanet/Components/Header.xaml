<UserControl x:Class="SportsPlanet.Components.Header"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="60">

    <Border Background="{StaticResource CardBg}" Padding="10">

        <Grid>

            <!-- 3 COLUMN LAYOUT -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ================= LEFT: BRAND ================= -->
            <TextBlock Text="Sports Planet"
                       Foreground="{StaticResource PrimaryText}"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <!-- ================= CENTER: NAVIGATION ================= -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <Button Name="AllProductsBtn" Content="All Products" Style="{StaticResource MenuButtonStyle}" Visibility="Collapsed" Click="HandleAllProductsClick"/>
                <Button Name="OrdersBtn"
                        Content="Orders"
                        Click="GoToOrdersPage"
                        Style="{StaticResource MenuButtonStyle}"
                        Visibility="Collapsed"/>

                <Button Click="HandleManageProductsClick" Name="ManageProductsBtn" Content="Manage Products" Style="{StaticResource MenuButtonStyle}" Visibility="Collapsed"/>
                <Button Click="HandleReportsBtnClick"  Name="ReportsBtn" Content="Reports" Style="{StaticResource MenuButtonStyle}" Visibility="Collapsed"/>
                <Button Click="HandlePendingOrdersClick" Name="PendingOrdersBtn" Content="Pending Orders" Style="{StaticResource MenuButtonStyle}" Visibility="Collapsed"/>
                <Button Click="HandleDispatchedOrdersClick" Name="DispatchedOrdersBtn" Content="Dispatched Orders" Style="{StaticResource MenuButtonStyle}" Visibility="Collapsed"/>
                <Button Click="HandleCreateAdminClick" Name="CreateNewAdminAndSuperAdminBtn" Content="Create New Admin" Style="{StaticResource MenuButtonStyle}" Visibility="Collapsed"/>

            </StackPanel>

            <!-- ================= RIGHT: AUTH ================= -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">

                <Button Content="Login" Name="loginBtn" Click="LoginClick" Visibility="Collapsed"/>
                <Button Content="Signup" Name="signupBtn" Click="SignupClick" Visibility="Collapsed"/>
                <Button Content="Logout" Name="logoutBtn" Click="LogoutClick" Visibility="Collapsed"/>

            </StackPanel>

        </Grid>

    </Border>
</UserControl>