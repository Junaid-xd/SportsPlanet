
    
    <UserControl x:Class="SportsPlanet.Components.Header"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource CardBg}" Padding="15">
        <DockPanel>

            <TextBlock Text="Sports Planet"
                       Foreground="{StaticResource PrimaryText}"
                       FontSize="20"
                       FontWeight="Bold"
                       DockPanel.Dock="Left"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="New Arrivals" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="Bats" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="Balls" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="Badminton" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="Kits" Style="{StaticResource MenuButtonStyle}"/>

                <Button Content="Orders"
                        Click="GoToOrdersPage"
                        Style="{StaticResource MenuButtonStyle}"/>

                <Button Content="Cart" Style="{StaticResource MenuButtonStyle}"/>

                <Button Content="Login" Name="loginBtn" Click="LoginClick"/>
                <Button Content="Signup" Name="signupBtn" Click="SignupClick"/>
                <Button Content="Logout" Name="logoutBtn" Click="LogoutClick"/>

                <Button Content="Stats"
                        Style="{StaticResource MenuButtonStyle}"
                        Visibility="Collapsed"/>

                <Button Content="Manage Products"
                        Style="{StaticResource MenuButtonStyle}"
                        Visibility="Collapsed"/>

            </StackPanel>

        </DockPanel>
    </Border>

</UserControl>